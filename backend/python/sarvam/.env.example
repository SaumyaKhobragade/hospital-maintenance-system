# ============================================================
# Vitality AI Sidecar — LangGraph Microservice Configuration
# ============================================================

# --- LLM Provider ---
# Options: "ollama" | "groq"
LLM_PROVIDER=ollama

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:latest

# --- Groq Cloud ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# --- Sarvam AI (Transcription) ---
SARVAM_API_KEY=your_sarvam_api_subscription_key_here

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# --- MongoDB (Motor async driver) ---
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/vitality_ai?retryWrites=true&w=majority
MONGO_DB_NAME=vitality_ai

# --- Server ---
HOST=0.0.0.0
PORT=8003

# --- Java Spring Boot Sidecar target ---
JAVA_BACKEND_URL=http://localhost:9090
